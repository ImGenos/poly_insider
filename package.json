{
  "name": "polymarket-monitoring-bot",
  "version": "1.0.0",
  "description": "Production-ready microservice system for real-time Polymarket surveillance",
  "main": "dist/ingestor/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start:ingestor": "node dist/ingestor/index.js",
    "start:analyzer": "node dist/analyzer/index.js",
    "start": "start.bat",
    "restart": "restart.bat",
    "stop": "stop.bat",
    "status": "status.bat",
    "logs": "npx pm2 logs --lines 50",
    "logs:ingestor": "npx pm2 logs polymarket-ingestor --lines 100",
    "logs:analyzer": "npx pm2 logs polymarket-analyzer --lines 100",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:property": "jest --testPathPattern=tests/property",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ioredis": "^5.3.2",
    "node-telegram-bot-api": "^0.66.0",
    "pg": "^8.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "eslint": "^9.5.0",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  }
}
