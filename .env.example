# =============================================================================
# Polymarket Monitoring Bot — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — the bot will exit with code 1 if any of these are missing/empty
# -----------------------------------------------------------------------------

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send alerts to (use @username or numeric ID)
TELEGRAM_CHAT_ID=

# Alchemy API key for wallet profiling and funding graph analysis
ALCHEMY_API_KEY=

# Redis connection URL (e.g. redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# TimescaleDB (PostgreSQL) connection URL
TIMESCALEDB_URL=postgresql://polymarket:polymarket@localhost:5433/polymarket

# Polymarket CLOB WebSocket endpoint
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# -----------------------------------------------------------------------------
# OPTIONAL — detection thresholds (defaults shown)
# -----------------------------------------------------------------------------

# Minimum trade size in USDC to pass the noise filter (default: 5000)
MIN_TRADE_SIZE_USDC=5000

# Percentage price change within window to trigger rapid odds shift (default: 15)
RAPID_ODDS_SHIFT_PERCENT=15

# Time window in minutes for rapid odds shift detection (default: 5)
RAPID_ODDS_SHIFT_WINDOW_MINUTES=5

# Percentage of order book liquidity consumed to trigger whale alert (default: 20)
WHALE_ACTIVITY_PERCENT=20

# Maximum wallet age in hours to qualify as "new" for insider detection (default: 48)
INSIDER_WALLET_AGE_HOURS=48

# Minimum trade size in USDC for insider trading detection (default: 10000)
INSIDER_MIN_TRADE_SIZE=10000

# Time window in minutes for coordinated cluster detection (default: 10)
CLUSTER_WINDOW_MINUTES=10

# Minimum distinct wallets required to trigger a cluster alert (default: 3, min: 2)
CLUSTER_MIN_WALLETS=3

# Z-score threshold for statistical anomaly detection (default: 3.0)
ZSCORE_THRESHOLD=3.0

# Minimum sample count before Z-score detection activates (default: 30)
ZSCORE_MIN_SAMPLES=30

# Number of historical data points used for Z-score baseline (default: 100)
ZSCORE_BASELINE_WINDOW=100

# Comma-separated market categories considered "niche" for insider detection
# (default: sports,crypto)
NICHE_MARKET_CATEGORIES=sports,crypto

# Comma-separated list of known exchange wallet addresses (lowercase, 0x-prefixed)
# These wallets are excluded from common-funder detection
KNOWN_EXCHANGE_WALLETS=

# TTL in seconds for alert deduplication keys (default: 3600 = 1 hour)
ALERT_DEDUP_TTL_SECONDS=3600

# TTL in seconds for cluster alert deduplication keys (default: 600 = 10 minutes)
CLUSTER_DEDUP_TTL_SECONDS=600

# -----------------------------------------------------------------------------
# OPTIONAL — Smart Money Detector (Football Markets)
# -----------------------------------------------------------------------------

# Minimum trade size in USDC for smart money detection (default: 5000)
SMART_MONEY_MIN_TRADE_SIZE=5000

# Minimum confidence score (0-100) to trigger smart money alert (default: 80)
SMART_MONEY_CONFIDENCE_THRESHOLD=80

# TTL in seconds for wallet profile cache (default: 86400 = 24 hours)
SMART_MONEY_WALLET_CACHE_TTL=86400

# -----------------------------------------------------------------------------
# OPTIONAL — logging
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Absolute path to log file (if omitted, logs to console only)
LOG_FILE_PATH=

# -----------------------------------------------------------------------------
# OPTIONAL — fallback APIs
# -----------------------------------------------------------------------------

# Moralis API key (used as fallback when Alchemy wallet lookup fails)
MORALIS_API_KEY=
